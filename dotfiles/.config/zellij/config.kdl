theme "gruvbox"
default_layout "battlestation"
default_mode "normal"
pane_frames true
mouse_mode true
copy_command "pbcopy"
copy_clipboard "system"
show_startup_tips false
show_release_notes false

web_client {
    font "monospace"
}
