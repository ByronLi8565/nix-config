keybinds clear-defaults=true {
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }

    normal {
        bind "Ctrl h" { MoveFocus "Left"; }
        bind "Ctrl j" { MoveFocus "Down"; }
        bind "Ctrl k" { MoveFocus "Up"; }
        bind "Ctrl l" { MoveFocus "Right"; }

        bind "Ctrl Shift h" { MovePane "Left"; }
        bind "Ctrl Shift j" { MovePane "Down"; }
        bind "Ctrl Shift k" { MovePane "Up"; }
        bind "Ctrl Shift l" { MovePane "Right"; }

        bind "Ctrl Alt h" { Resize "Increase Left"; }
        bind "Ctrl Alt j" { Resize "Increase Down"; }
        bind "Ctrl Alt k" { Resize "Increase Up"; }
        bind "Ctrl Alt l" { Resize "Increase Right"; }
        bind "Ctrl Shift Alt h" { Resize "Decrease Left"; }
        bind "Ctrl Shift Alt j" { Resize "Decrease Down"; }
        bind "Ctrl Shift Alt k" { Resize "Decrease Up"; }
        bind "Ctrl Shift Alt l" { Resize "Decrease Right"; }

        bind "Super h" { GoToPreviousTab; }
        bind "Super l" { GoToNextTab; }
        bind "Super Shift h" { MoveTab "Left"; }
        bind "Super Shift l" { MoveTab "Right"; }
        bind "Super t" { NewTab; }
        bind "Super w" { CloseTab; }
        bind "Super 1" { GoToTab 1; }
        bind "Super 2" { GoToTab 2; }
        bind "Super 3" { GoToTab 3; }
        bind "Super 4" { GoToTab 4; }
        bind "Super 5" { GoToTab 5; }
        bind "Super 6" { GoToTab 6; }
        bind "Super 7" { GoToTab 7; }
        bind "Super 8" { GoToTab 8; }
        bind "Super 9" { GoToTab 9; }

        bind "Ctrl d" { NewPane "Down"; }
        bind "Ctrl r" { NewPane "Right"; }
        bind "Ctrl s" { NewPane "stacked"; }
        bind "Ctrl f" { ToggleFocusFullscreen; }
        bind "Ctrl Space" {
            Run "fish" {
                name "scratch"
                floating true
                close_on_exit true
                x "7%"
                y "9%"
                width "86%"
                height "78%"
            }
        }
        bind "Ctrl Shift w" { CloseFocus; }

        bind "Alt [" { PreviousSwapLayout; }
        bind "Alt ]" { NextSwapLayout; }
        bind "Alt f" { ToggleFloatingPanes; }
        bind "Alt p" { TogglePaneInGroup; }
        bind "Alt Shift p" { ToggleGroupMarking; }
        bind "Ctrl g" { SwitchToMode "Locked"; }
        bind "Ctrl q" { Detach; }
    }

    scroll {
        bind "Esc" "Ctrl c" { ScrollToBottom; SwitchToMode "Normal"; }
        bind "s" { SwitchToMode "EnterSearch"; SearchInput 0; }
        bind "e" { EditScrollback; SwitchToMode "Normal"; }
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "Ctrl f" "PageDown" "Right" "l" { PageScrollDown; }
        bind "Ctrl b" "PageUp" "Left" "h" { PageScrollUp; }
    }

    search {
        bind "Esc" "Ctrl c" { ScrollToBottom; SwitchToMode "Normal"; }
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "n" { Search "Down"; }
        bind "p" { Search "Up"; }
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "w" { SearchToggleOption "Wrap"; }
        bind "o" { SearchToggleOption "WholeWord"; }
    }

    entersearch {
        bind "Esc" "Ctrl c" { SwitchToMode "Scroll"; }
        bind "Enter" { SwitchToMode "Search"; }
    }
}

plugins {
    compact-bar location="zellij:compact-bar"
    session-manager location="zellij:session-manager"
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
    about location="zellij:about"
    strider location="zellij:strider"
}

